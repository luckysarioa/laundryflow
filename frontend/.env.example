# ==========================================================
# LaundryFlow Frontend — Environment Variables
# ==========================================================
# Salin file ini menjadi ".env.local" lalu sesuaikan nilainya.

# Gunakan mock data (true) atau backend Laravel sungguhan (false).
# Saat false, semua request akan diarahkan ke NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_USE_MOCK=true

# Base URL backend Laravel (hanya dipakai jika NEXT_PUBLIC_USE_MOCK=false).
# Contoh: http://localhost:8000/api
NEXT_PUBLIC_API_URL=
