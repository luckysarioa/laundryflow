# ==========================================================
# LaundryFlow — Docker / Coolify Environment
# ==========================================================
# Salin menjadi ".env":  cp .env.docker.example .env
# Lalu edit nilai bertanda [GANTI].
#
# ARSITEKTUR: Coolify routing 2 domain (Coolify terminate HTTPS):
#   - app.domain.com  → port frontend (default 3000)
#   - api.domain.com  → port backend  (default 8081)
# ==========================================================

# ---------- Laravel App ----------
# [GANTI] APP_KEY WAJIB diisi agar persisten antar redeploy.
#   Bila kosong, entrypoint generate key baru tiap container recreate
#   → SEMUA session/token Sanctum invalid setiap deploy (user logout).
#   Generate: docker run --rm php:8.2-cli php -r "echo 'base64:'.base64_encode(random_bytes(32));"
APP_KEY=
# [GANTI] URL publik BACKEND (api). Dipakai untuk storage URL & link WhatsApp.
#   Contoh: https://api.domainanda.com
APP_URL=http://localhost:8081
# "production" (default) → seeder dilewati (tabel kosong). "local"/"staging" → seed data demo.
APP_ENV=production
APP_DEBUG=false

# ---------- Database (MySQL) ----------
DB_DATABASE=laundryflow
DB_USERNAME=laundryflow
# [GANTI] password DB dengan string acak kuat.
DB_PASSWORD=changeme_strong_password
DB_ROOT_PASSWORD=changeme_root_password

# ---------- CORS & Session (arsitektur 2-domain) ----------
# [GANTI] Origin FRONTEND yang diizinkan memanggil API (CORS).
#   Contoh: https://app.domainanda.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Domain yang dianggap stateful Sanctum (cookie-based). Bisa kosong untuk token auth.
SANCTUM_STATEFUL_DOMAINS=
# Scope cookie session. Kosongkan untuk current host.
SESSION_DOMAIN=
# Set "true" bila API & frontend sama-sama HTTPS di produksi (cookie aman).
SESSION_SECURE_COOKIE=false

# ---------- Frontend (Next.js, build-time) ----------
# [GANTI] URL absolut backend API. Build-time → butuh REBUILD frontend bila ganti domain.
#   Contoh: https://api.domainanda.com/api
NEXT_PUBLIC_USE_MOCK=false
NEXT_PUBLIC_API_URL=http://localhost:8081/api

# ---------- Port host (Coolify map domain ke sini) ----------
# Default: backend 8081, frontend 3000. Di Coolify, set domain → port ini.
BACKEND_PORT=8081
FRONTEND_PORT=3000

# ---------- Backup Database (otomatis) ----------
# Format cron standar (menit jam tgl-bulan hari-dlm-minggu). Default: tiap hari 01:00.
BACKUP_SCHEDULE=0 1 * * *
# Berapa hari backup disimpan sebelum otomatis dihapus (rotasi).
BACKUP_RETENTION_DAYS=7
# Kompresi: "gzip" (default, .sql.gz) atau "none" (.sql mentah).
BACKUP_COMPRESS=gzip
# Jalankan backup sekali saat container start? (true/false)
BACKUP_ON_START=true
