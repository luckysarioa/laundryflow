# ==========================================================
# LaundryFlow — Docker / Coolify Environment
# ==========================================================
# Salin menjadi ".env":  cp .env.docker.example .env
# Lalu edit nilai, terutama APP_KEY, domain, dan password DB.
# ==========================================================

# ---------- Laravel APP_KEY ----------
# WAJIB. Generate dengan:  docker run --rm php:8.2-cli php -r "echo 'base64:'.base64_encode(random_bytes(32));"
# Tempel hasilnya setelah tanda = di bawah.
APP_KEY=
APP_URL=http://localhost

# ---------- Database (MySQL) ----------
DB_DATABASE=laundryflow
DB_USERNAME=laundryflow
# GANTI password ini dengan string acak yang kuat.
DB_PASSWORD=changeme_strong_password
DB_ROOT_PASSWORD=changeme_root_password

# ---------- Frontend (Next.js build-time) ----------
# Frontend memanggil API via reverse proxy (path "/api"), jadi relatif.
# Untuk Coolify dengan domain publik, set: https://domainanda.com/api
NEXT_PUBLIC_API_URL=/api

# ---------- Caddy Reverse Proxy ----------
# Mode LOKAL (HTTP tanpa HTTPS, akses via IP:port):
CADDY_DOMAIN=:80
HTTP_PORT=8080
# HTTPS_PORT=8443

# --- atau MODE DOMAIN PUBLIK (auto-HTTPS via Let's Encrypt) ---
# Hapus/comment baris CADDY_DOMAIN=:80 di atas, lalu uncomment & set domain:
# CADDY_DOMAIN=laundryflow.contoh.com
# HTTP_PORT=80
# HTTPS_PORT=443

# ---------- Backup Database (otomatis) ----------
# Format cron standar (menit jam tgl-bulan hari-dlm-minggu).
# Default: tiap hari jam 01:00 dinihari.
BACKUP_SCHEDULE=0 1 * * *
# Berapa hari backup disimpan sebelum otomatis dihapus (rotasi).
BACKUP_RETENTION_DAYS=7
# Kompresi: "gzip" (default, file .sql.gz) atau "none" (.sql mentah).
BACKUP_COMPRESS=gzip
# Jalankan backup sekali saat container start? (true/false)
BACKUP_ON_START=true
