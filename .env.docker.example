# ==========================================================
# LaundryFlow — Docker / Coolify Environment
# ==========================================================
# Deploy tanpa domain custom → pakai default Coolify (*.coolify.app)
# Coolify otomatis generate domain: xxx.app.coolify.io
# ==========================================================

# ---------- Laravel App ----------
# Generate: docker run --rm php:8.2-cli php -r "echo 'base64:'.base64_encode(random_bytes(32));"
APP_KEY=
# URL backend dari Coolify (otomatis): https://xxx-backend.app.coolify.io
APP_URL=http://localhost:8081
APP_ENV=production
APP_DEBUG=false

# ---------- Database (MySQL) ----------
DB_DATABASE=laundryflow
DB_USERNAME=laundryflow
DB_PASSWORD=laundryflow123
DB_ROOT_PASSWORD=laundryflowroot

# ---------- CORS & Session ----------
CORS_ALLOWED_ORIGINS=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false

# ---------- Super Admin ----------
# Akun superadmin di-seed otomatis saat start container (SystemDataSeeder).
# Ganti password default demi keamanan produksi.
SUPERADMIN_EMAIL=superadmin@laundryflow.id
SUPERADMIN_NAME=Super Admin
SUPERADMIN_PASSWORD=password

# ---------- URL Frontend ----------
FRONTEND_URL=http://localhost:3000

# ---------- Midtrans (opsional) ----------
MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/sheet.js
MIDTRANS_API_URL=https://api.sandbox.midtrans.com
MIDTRANS_NOTIFICATION_SECRET=

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_USE_MOCK=false
NEXT_PUBLIC_API_URL=http://localhost:8081/api

# ---------- Port host ----------
BACKEND_PORT=8081
FRONTEND_PORT=3000

# ---------- Backup ----------
BACKUP_SCHEDULE=0 1 * * *
BACKUP_RETENTION_DAYS=7
BACKUP_COMPRESS=gzip
BACKUP_ON_START=true
