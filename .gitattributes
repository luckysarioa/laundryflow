# Default: biarkan git normalisasi teks (LF di repo, sesuai OS saat checkout).
* text=auto

# Paksa LF (bukan CRLF) untuk file yang berjalan di container Linux.
# CRLF akan membuat shell script (.sh) dan Dockerfile gagal di Alpine.
*.sh           text eol=lf
*.env          text eol=lf
.env*          text eol=lf
Dockerfile*    text eol=lf
Caddyfile      text eol=lf
docker-compose.yml text eol=lf
*.json         text eol=lf

# File biner — jangan diubah.
*.png  binary
*.jpg  binary
*.ico  binary
*.woff binary
*.woff2 binary
