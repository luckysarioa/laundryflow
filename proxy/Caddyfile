# ==========================================================
# LaundryFlow — Caddy Reverse Proxy
#
# Menyatukan frontend & backend dalam SATU domain:
#   - https://<domain>/api/*   → backend Laravel (port 80 internal)
#   - https://<domain>/*       → frontend Next.js (port 3000 internal)
#
# Keuntungan:
#   1. Single origin → tidak ada masalah CORS.
#   2. Frontend NEXT_PUBLIC_API_URL bisa relatif ("/api") → tidak perlu
#      rebuild saat ganti domain.
#   3. Caddy auto-TLS (HTTPS) via Let's Encrypt untuk domain publik.
#
# Variabel:
#   {$DOMAIN}  — domain/alamat (mis. laundryflow.com atau :8080 untuk lokal)
# ==========================================================

{$DOMAIN} {
	# --- API backend ---
	@apis path /api /api/*
	handle @apis {
		reverse_proxy backend:80
	}

	# --- Frontend Next.js (semua route lain) ---
	handle {
		reverse_proxy frontend:3000
	}

	# Header keamanan dasar.
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}
}
