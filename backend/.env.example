APP_NAME=LaundryFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ----- Database (MySQL sesuai PRD) -----
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laundryflow
DB_USERNAME=root
DB_PASSWORD=

# ----- Session / Cache / Queue -----
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# ----- Sanctum Stateful Domains (frontend dev) -----
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DOMAIN=localhost

# ----- Super Admin (default superadmin@laundryflow.id / password) -----
# CATATAN: value yang mengandung spasi WAJIB dikutip (dotenv strict mode).
SUPERADMIN_EMAIL=superadmin@laundryflow.id
SUPERADMIN_NAME="Super Admin"
SUPERADMIN_PASSWORD=password
